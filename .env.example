# ─── API CONFIG ──────────────────────────────────────────────────
PROJECT_NAME="NewsCraft AI"
API_V1_STR="/api/v1"
SECRET_KEY="your-super-secret-key-for-jwt-signing"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# ─── DATABASE ────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase)
DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"

# ─── SUPABASE ────────────────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="newscraft-clippings"

# ─── AI ENGINE (xAI Grok) ────────────────────────────────────────
GROK_API_KEY="your-grok-api-key"

# ─── PAYMENTS (Stripe) ───────────────────────────────────────────
STRIPE_API_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."

# ─── REDIS & CELERY ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# ─── EMAIL (Optional) ────────────────────────────────────────────
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST="smtp.gmail.com"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAILS_FROM_EMAIL="noreply@newscraft-ai.com"

# ─── DEPLOYMENT ──────────────────────────────────────────────────
ENVIRONMENT="development" # development, production
CORS_ORIGINS=["http://localhost:3000", "https://newscraft-ai.vercel.app"]
